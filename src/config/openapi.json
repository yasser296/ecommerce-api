{
  "openapi": "3.0.3",
  "info": {
    "title": "E-Commerce Marketplace API",
    "version": "1.0.0",
    "description": "REST API for an E-Commerce Marketplace Application built with Express and PostgreSQL."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "tags": [
    { "name": "Products", "description": "Product endpoints" },
    { "name": "Sellers", "description": "Seller endpoints" },
    { "name": "Orders", "description": "Order endpoints" },
    { "name": "Categories", "description": "Category endpoints" }
  ],
  "components": {
    "parameters": {
      "ProductId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "Product id"
      },
      "SellerId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "Seller id"
      },
      "OrderId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "description": "Order id"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": { "type": "string", "example": "BODY_NOT_VALID" },
          "message": { "type": "string", "example": "Invalid request body" },
          "details": { "type": "string", "example": "Only price and stock can be updated" }
        }
      },

      "Address": {
        "type": "object",
        "properties": {
          "street": { "type": "string", "example": "Rue 10" },
          "city": { "type": "string", "example": "Casablanca" },
          "country": { "type": "string", "example": "Morocco" },
          "zipCode": { "type": "string", "example": "20000" }
        },
        "required": ["street", "city", "country", "zipCode"]
      },

      "SellerPreview": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "storeName": { "type": "string", "example": "Tech Store" },
          "rating": { "type": "number", "example": 4.7 }
        }
      },

      "Seller": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "storeName": { "type": "string", "example": "Tech Store" },
          "email": { "type": "string", "example": "techstore@example.com" },
          "phone": { "type": "string", "example": "+212600000000" },
          "address": { "$ref": "#/components/schemas/Address" },
          "rating": { "type": "number", "example": 4.7 },
          "createdAt": { "type": "string", "example": "Tuesday, April 7, 2026 at 4:35:48 PM UTC" }
        }
      },

      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "example": "electronics" }
        }
      },

      "ProductPreview": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "example": "Mouse X" },
          "price": { "type": "number", "example": 1700 },
          "thumbnail": { "type": "string", "example": "https://example.com/mouse.jpg" },
          "category": { "type": "string", "example": "electronics" },
          "createdAt": { "type": "string", "example": "mardi 7 avril 2026 à 16:35:48 UTC" }
        }
      },

      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "example": "Mouse X" },
          "description": { "type": "string", "example": "Wireless mouse for office and gaming" },
          "price": { "type": "number", "example": 1700 },
          "currency": { "type": "string", "example": "USD" },
          "stock": { "type": "integer", "example": 7 },
          "images": {
            "type": "array",
            "items": { "type": "string" }
          },
          "category": { "$ref": "#/components/schemas/Category" },
          "createdAt": { "type": "string" },
          "seller": { "$ref": "#/components/schemas/SellerPreview" },
          "_links": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },

      "ProductCreateInput": {
        "type": "object",
        "required": ["name", "description", "price", "currency", "stock", "categoryId", "sellerId"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 100 },
          "description": { "type": "string", "minLength": 10, "maxLength": 2000 },
          "price": { "type": "number", "minimum": 0.01 },
          "currency": { "type": "string", "minLength": 3, "maxLength": 3, "example": "USD" },
          "stock": { "type": "integer", "minimum": 0 },
          "thumbnail": { "type": "string", "example": "https://example.com/mouse.jpg" },
          "categoryId": { "type": "string", "format": "uuid" },
          "sellerId": { "type": "string", "format": "uuid" }
        }
      },

      "ProductUpdateInput": {
        "type": "object",
        "properties": {
          "price": { "type": "number", "minimum": 0.01 },
          "stock": { "type": "integer", "minimum": 0 }
        }
      },

      "SellerCreateInput": {
        "type": "object",
        "required": ["storeName", "email", "phone", "address"],
        "properties": {
          "storeName": { "type": "string", "example": "Book World" },
          "email": { "type": "string", "example": "bookworld@example.com" },
          "phone": { "type": "string", "example": "+212611111111" },
          "address": { "$ref": "#/components/schemas/Address" },
          "rating": { "type": "number", "example": 4.3 }
        }
      },

      "SellerUpdateInput": {
        "type": "object",
        "properties": {
          "storeName": { "type": "string" },
          "phone": { "type": "string" },
          "address": {
            "type": "object",
            "properties": {
              "street": { "type": "string" },
              "city": { "type": "string" },
              "country": { "type": "string" },
              "zipCode": { "type": "string" }
            }
          },
          "rating": { "type": "number", "minimum": 0, "maximum": 5 }
        }
      },

      "OrderCreateInput": {
        "type": "object",
        "required": ["customerName", "products", "totalAmount", "shippingAddress"],
        "properties": {
          "customerName": { "type": "string", "example": "Amine" },
          "products": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "totalAmount": { "type": "number", "example": 1500 },
          "shippingAddress": { "$ref": "#/components/schemas/Address" }
        }
      },

      "OrderStatusUpdateInput": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["pending", "paid", "shipped", "delivered"]
          }
        }
      },

      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "customerName": { "type": "string", "example": "Amine" },
          "products": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductPreview" }
          },
          "totalAmount": { "type": "number", "example": 1500 },
          "status": {
            "type": "string",
            "enum": ["pending", "paid", "shipped", "delivered"]
          },
          "createdAt": { "type": "string" },
          "_links": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },

      "ProductListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ProductPreview" }
          },
          "total": { "type": "integer", "example": 2 },
          "page": { "type": "integer", "example": 1 },
          "limit": { "type": "integer", "example": 10 },
          "_links": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "paths": {
    "/api/v1/products": {
      "get": {
        "tags": ["Products"],
        "summary": "Get products list",
        "description": "Returns a paginated list of products with filtering, sorting and search options.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10 }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": { "type": "string", "enum": ["createdAt", "price", "name"] }
          },
          {
            "name": "order",
            "in": "query",
            "schema": { "type": "string", "enum": ["asc", "desc"] }
          },
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "sellerId",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "minPrice",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "schema": { "type": "number" }
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "schema": { "type": "string", "enum": ["en", "fr"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Products list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ProductListResponse" }
              },
              "application/xml": {
                "schema": { "type": "string" }
              }
            }
          },
          "400": {
            "description": "Invalid query/body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create a product",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductCreateInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "400": {
            "description": "Invalid body",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },

    "/api/v1/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by id",
        "parameters": [{ "$ref": "#/components/parameters/ProductId" }],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "404": {
            "description": "Resource not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Products"],
        "summary": "Update product price and stock",
        "parameters": [{ "$ref": "#/components/parameters/ProductId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductUpdateInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          },
          "400": {
            "description": "Invalid body/params",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "404": {
            "description": "Product not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product",
        "parameters": [{ "$ref": "#/components/parameters/ProductId" }],
        "responses": {
          "204": {
            "description": "Product deleted"
          },
          "404": {
            "description": "Product not found"
          }
        }
      }
    },

    "/api/v1/products/{id}/seller": {
      "get": {
        "tags": ["Products"],
        "summary": "Get seller of a product",
        "parameters": [{ "$ref": "#/components/parameters/ProductId" }],
        "responses": {
          "200": {
            "description": "Seller of the product",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Seller" }
              }
            }
          }
        }
      }
    },

    "/api/v1/products/{id}/category": {
      "get": {
        "tags": ["Products"],
        "summary": "Get category of a product",
        "parameters": [{ "$ref": "#/components/parameters/ProductId" }],
        "responses": {
          "200": {
            "description": "Category of the product",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Category" }
              }
            }
          }
        }
      }
    },

    "/api/v1/sellers": {
      "get": {
        "tags": ["Sellers"],
        "summary": "Get sellers list",
        "responses": {
          "200": {
            "description": "Sellers list"
          }
        }
      },
      "post": {
        "tags": ["Sellers"],
        "summary": "Create seller",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SellerCreateInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Seller created" },
          "400": { "description": "Invalid body" }
        }
      }
    },

    "/api/v1/sellers/{id}": {
      "get": {
        "tags": ["Sellers"],
        "summary": "Get seller by id",
        "parameters": [{ "$ref": "#/components/parameters/SellerId" }],
        "responses": {
          "200": { "description": "Seller details" },
          "404": { "description": "Seller not found" }
        }
      },
      "patch": {
        "tags": ["Sellers"],
        "summary": "Update seller except email",
        "parameters": [{ "$ref": "#/components/parameters/SellerId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SellerUpdateInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Seller updated" },
          "400": { "description": "Invalid body" },
          "404": { "description": "Seller not found" }
        }
      },
      "delete": {
        "tags": ["Sellers"],
        "summary": "Delete seller",
        "parameters": [{ "$ref": "#/components/parameters/SellerId" }],
        "responses": {
          "204": { "description": "Seller deleted" }
        }
      }
    },

    "/api/v1/sellers/{sellerId}/products": {
      "get": {
        "tags": ["Sellers"],
        "summary": "Get products of a seller",
        "parameters": [
          {
            "name": "sellerId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Products of seller"
          }
        }
      }
    },

    "/api/v1/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get orders list",
        "parameters": [
          {
            "name": "productId",
            "in": "query",
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "customerName",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Orders list" }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderCreateInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created" },
          "400": { "description": "Invalid body" }
        }
      }
    },

    "/api/v1/orders/{id}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order by id",
        "parameters": [{ "$ref": "#/components/parameters/OrderId" }],
        "responses": {
          "200": { "description": "Order details" },
          "404": { "description": "Order not found" }
        }
      },
      "delete": {
        "tags": ["Orders"],
        "summary": "Delete order",
        "parameters": [{ "$ref": "#/components/parameters/OrderId" }],
        "responses": {
          "204": { "description": "Order deleted" }
        }
      }
    },

    "/api/v1/orders/{id}/status": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status",
        "parameters": [{ "$ref": "#/components/parameters/OrderId" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderStatusUpdateInput" }
            }
          }
        },
        "responses": {
          "200": { "description": "Order status updated" },
          "400": { "description": "Invalid body" }
        }
      }
    },

    "/api/v1/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "Get categories list",
        "responses": {
          "200": {
            "description": "Categories list"
          }
        }
      }
    },

    "/api/v1/categories/{categoryId}/products": {
      "get": {
        "tags": ["Categories"],
        "summary": "Get products of a category",
        "parameters": [
          {
            "name": "categoryId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Products of category"
          }
        }
      }
    }
  }
}